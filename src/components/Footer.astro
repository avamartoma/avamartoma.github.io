---
const year = new Date().getFullYear();
const socials = [
  { href: 'https://www.linkedin.com/in/avamartoma/', label: 'LinkedIn' },
  { href: 'https://github.com/avamartoma', label: 'GitHub' },
  { href: 'mailto:ava.martoma@gmail.com', label: 'Email' },
];
---

<footer class="foot" id="contact">
  <div class="wrap foot__inner">
    <nav class="foot__socials" aria-label="Contact links">
      {socials.map((s) => (
        <a
          href={s.href}
          class="arrow-link"
          target={s.href.startsWith('mailto:') ? undefined : '_blank'}
          rel="noopener"
        >
          {s.label} <span>↗</span>
        </a>
      ))}
    </nav>

    <div class="foot__meta">
      <span class="label">© {year} Ava Martoma</span>
      <span class="label">Built with Astro</span>
    </div>
  </div>
</footer>

<style>
  .foot {
    border-top: 1px solid var(--line);
    padding-block: 1.5rem;
    margin-top: 3rem;
  }
  .foot__inner {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem 2rem;
    justify-content: space-between;
    align-items: center;
  }
  .foot__socials { display: flex; gap: 1.5rem; }
  .foot__meta {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem 1.5rem;
    align-items: center;
  }
</style>
