---
// Spotify "Lately" widget — FRONTEND ONLY (path-agnostic).
//
// Fetches a JSON endpoint (a Cloudflare Worker — see worker/ + HANDOVER §6) that
// returns what Ava is playing now + recently played. The endpoint holds the
// Spotify secret + refresh token server-side. NEVER put the client secret or
// refresh token in this file or any client code (public repo!).
//
// Expected JSON contract from the endpoint:
//   {
//     "isPlaying": boolean,
//     "current":   { title, artist, album, albumImageUrl, songUrl } | null,
//     "recent":    [ { title, artist, album, albumImageUrl, songUrl, playedAt }, ... ]
//   }
//
// The Worker URL is public/non-sensitive; only the secret (a Wrangler secret)
// isn't. Override per-env with PUBLIC_SPOTIFY_ENDPOINT.
const SPOTIFY_ENDPOINT =
  import.meta.env.PUBLIC_SPOTIFY_ENDPOINT ||
  'https://avamartoma-now-playing.avamartoma.workers.dev';
const showDemo = !SPOTIFY_ENDPOINT && import.meta.env.DEV;
const render = Boolean(SPOTIFY_ENDPOINT) || showDemo;
---

{render && (
  <div class="np" data-np data-np-endpoint={SPOTIFY_ENDPOINT} data-np-demo={showDemo ? 'true' : 'false'} aria-live="polite">
    <p class="np__head">What I've been listening to</p>
    <div class="np__list" data-np-list></div>
  </div>
)}

<style is:global>
  /* Global (not scoped): the track rows are injected at runtime via innerHTML,
     so Astro's scoped-style attribute never reaches them. The `.np__*` prefix
     keeps these from colliding with anything else. */
  .np {
    border: 1px solid var(--line);
    border-radius: var(--radius);
    padding: 1.1rem 1.25rem;
    background: var(--bg-soft);
    display: grid;
    gap: 0.85rem;
  }
  .np__head {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--signal-4);
    margin: 0;
  }

  .np__list { display: grid; gap: 0.7rem; }

  /* A track row: album art + text + equalizer icon. */
  .np__row {
    display: grid;
    grid-template-columns: 44px 1fr auto;
    gap: 0.75rem;
    align-items: center;
    min-width: 0;
  }
  .np__row--current { grid-template-columns: 56px 1fr auto; }

  .np__art {
    width: 44px; height: 44px;
    border-radius: 7px;
    background: linear-gradient(135deg, var(--signal), var(--signal-2));
    background-size: cover;
    background-position: center;
    flex: 0 0 auto;
  }
  .np__row--current .np__art { width: 56px; height: 56px; border-radius: 8px; }

  .np__meta { display: grid; gap: 0.15rem; min-width: 0; }
  .np__line {
    font-size: 0.9rem;
    white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
  }
  .np__row--current .np__line { font-size: 1rem; }
  .np__song {
    color: var(--ink);
    text-decoration: none;
    transition: color 0.2s var(--ease);
  }
  .np__song:hover { color: var(--signal); }
  .np__by { color: var(--ink-soft); }
  .np__when {
    font-size: 0.72rem;
    color: var(--muted);
    white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
  }

  /* Equalizer icon, one per row.
     --live  = animated green (the track playing right now)
     --static = frozen gray bars (played earlier, not anymore) */
  .np__eq {
    display: inline-flex;
    align-items: flex-end;
    gap: 2px;
    height: 16px;
    flex: 0 0 auto;
  }
  .np__eq i {
    width: 3px; height: 100%;
    border-radius: 1px;
    transform-origin: bottom;
    transform: scaleY(0.4);
  }

  .np__eq--live i { background: var(--signal-4); animation: np-bar 0.9s ease-in-out infinite; }
  .np__eq--live i:nth-child(2) { animation-delay: 0.2s; }
  .np__eq--live i:nth-child(3) { animation-delay: 0.4s; }

  .np__eq--static i { background: var(--ink-soft); opacity: 0.8; }
  .np__eq--static i:nth-child(1) { transform: scaleY(0.5); }
  .np__eq--static i:nth-child(2) { transform: scaleY(0.95); }
  .np__eq--static i:nth-child(3) { transform: scaleY(0.6); }

  @keyframes np-bar {
    0%, 100% { transform: scaleY(0.3); }
    50%      { transform: scaleY(1); }
  }
  @media (prefers-reduced-motion: reduce) {
    .np__eq--live i { animation: none; transform: scaleY(0.7); }
  }
</style>

<script>
  interface Track {
    title: string;
    artist: string;
    album?: string;
    albumImageUrl?: string;
    songUrl?: string;
    playedAt?: string | null;
  }
  interface Payload {
    isPlaying: boolean;
    current: Track | null;
    recent: Track[];
  }

  const root = document.querySelector<HTMLElement>('[data-np]');
  if (root) {
    const endpoint = root.dataset.npEndpoint || '';
    const isDemo = root.dataset.npDemo === 'true';
    const list = root.querySelector<HTMLElement>('[data-np-list]');

    const esc = (s: string) =>
      (s || '').replace(/[&<>"']/g, (c) =>
        ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;' }[c] as string));

    // Human "x ago" from an ISO timestamp.
    const timeAgo = (iso?: string | null) => {
      if (!iso) return '';
      const ms = Date.now() - new Date(iso).getTime();
      if (!Number.isFinite(ms) || ms < 0) return '';
      const min = Math.floor(ms / 60000);
      if (min < 1) return 'just now';
      if (min < 60) return `${min} minute${min === 1 ? '' : 's'} ago`;
      const hr = Math.floor(min / 60);
      if (hr < 24) return `${hr} hour${hr === 1 ? '' : 's'} ago`;
      const day = Math.floor(hr / 24);
      return `${day} day${day === 1 ? '' : 's'} ago`;
    };

    // Equalizer icon: green + animated for the live track, gray + frozen otherwise.
    const eq = (live: boolean) =>
      `<span class="np__eq np__eq--${live ? 'live' : 'static'}" aria-hidden="true"><i></i><i></i><i></i></span>`;

    const rowHtml = (t: Track, current = false) => {
      const art = t.albumImageUrl
        ? ` style="background-image:url('${esc(t.albumImageUrl)}')"`
        : '';
      const song = t.songUrl
        ? `<a class="np__song" href="${esc(t.songUrl)}" target="_blank" rel="noopener">${esc(t.title)}</a>`
        : `<span class="np__song">${esc(t.title)}</span>`;
      const when = current ? 'right now' : timeAgo(t.playedAt);
      return `<div class="np__row${current ? ' np__row--current' : ''}">
        <div class="np__art"${art} aria-hidden="true"></div>
        <div class="np__meta">
          <span class="np__line">${song}<span class="np__by"> by ${esc(t.artist)}</span></span>
          ${when ? `<span class="np__when">${esc(when)}</span>` : ''}
        </div>
        ${eq(current)}
      </div>`;
    };

    const paint = (data: Payload) => {
      const playing = !!data.isPlaying && !!data.current;
      const rows: string[] = [];
      if (playing && data.current) rows.push(rowHtml(data.current, true));
      const recent = Array.isArray(data.recent) ? data.recent : [];
      // Fewer recent when a live track is on top, so the card stays tidy.
      const max = playing ? 4 : 5;
      for (const t of recent.slice(0, max)) rows.push(rowHtml(t));
      if (list) list.innerHTML = rows.join('') || '<p class="np__when">Nothing to show right now.</p>';
    };

    if (isDemo) {
      paint({
        isPlaying: true,
        current: { title: 'Demo Track (dev preview)', artist: 'Connect Spotify', songUrl: 'https://open.spotify.com' },
        recent: [
          { title: 'Previous Song', artist: 'Some Artist', playedAt: new Date(Date.now() - 8 * 60000).toISOString() },
          { title: 'Another One', artist: 'Another Artist', playedAt: new Date(Date.now() - 3 * 3600000).toISOString() },
        ],
      });
    } else if (endpoint) {
      const refresh = async () => {
        try {
          const res = await fetch(endpoint, { cache: 'no-store' });
          if (!res.ok) throw new Error(String(res.status));
          const data: Payload = await res.json();
          paint(data);
        } catch {
          if (list) list.innerHTML = '<p class="np__when">Couldn’t load right now.</p>';
        }
      };
      refresh();
      // Light polling so "now playing" stays fresh without hammering the endpoint.
      setInterval(refresh, 60_000);
    }
  }
</script>
