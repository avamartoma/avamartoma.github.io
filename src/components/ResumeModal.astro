---
// Minimalist resume-request popover. Opens anchored just under whatever
// [data-open-resume] element was clicked (the nav "Resume" link), leaving the
// whole page visible behind it — no dimming backdrop.
//
// EMAIL DELIVERY — Web3Forms (works on GitHub Pages, no backend needed):
//   1. Go to https://web3forms.com, enter ava.martoma@gmail.com, and you'll be
//      emailed a free Access Key.
//   2. Paste that key into WEB3FORMS_ACCESS_KEY below (replace the placeholder).
// After that, every submission emails ava.martoma@gmail.com with the requester's
// address (reply-to is set to them, so you can reply with the PDF directly).
// Until the real key is added, the popup shows the thank-you but does NOT send.
const WEB3FORMS_ACCESS_KEY = 'YOUR_WEB3FORMS_ACCESS_KEY';
---

<div id="resume-pop" class="rm" role="dialog" aria-label="Request my resume" hidden>
  <form class="rm__form">
    <input type="hidden" name="access_key" value={WEB3FORMS_ACCESS_KEY} />
    <input type="hidden" name="subject" value="Someone requested your resume" />
    <input type="hidden" name="from_name" value="Resume popup — avamartoma.com" />
    <!-- Web3Forms honeypot: bots fill this, humans can't see it -->
    <input type="checkbox" name="botcheck" class="rm__hp" tabindex="-1" autocomplete="off" />

    <h2 class="rm__title">Drop your email &amp; I'll send it to you.</h2>

    <div class="rm__row">
      <input
        type="email"
        name="email"
        required
        autocomplete="email"
        placeholder="you@email.com"
        aria-label="Your email"
        class="rm__input"
      />
      <button type="submit" class="rm__go" aria-label="Send request">
        <span aria-hidden="true">→</span>
      </button>
    </div>
  </form>

  <div class="rm__done" data-resume-done hidden>
    <h2 class="rm__title">Sent. ✦ I'll email it over.</h2>
  </div>
</div>

<style>
  .rm {
    position: fixed;
    z-index: 200;
    width: min(21rem, calc(100vw - 2rem));
    background: var(--surface);
    color: var(--ink);
    border: 1px solid var(--line);
    border-radius: 10px;
    padding: 1.25rem 1.25rem 1.35rem;
    box-shadow: 0 18px 50px rgba(0, 0, 0, 0.5);
    overflow: hidden;
  }
  .rm[hidden] { display: none; }
  .rm::before {
    content: '';
    position: absolute;
    inset: 0 0 auto 0;
    height: 3px;
    background: linear-gradient(90deg, var(--signal), var(--signal-2));
  }
  .rm.is-open { animation: rm-in 0.22s var(--ease); }
  @keyframes rm-in {
    from { opacity: 0; transform: translateY(-8px); }
    to   { opacity: 1; transform: none; }
  }

  .rm__title {
    font-size: 1.05rem;
    line-height: 1.25;
    margin-bottom: 1rem;
  }

  .rm__row { display: flex; align-items: stretch; gap: 0.5rem; }
  .rm__input {
    flex: 1;
    min-width: 0;
    font-family: var(--font-mono);
    font-size: 0.9rem;
    color: var(--ink);
    background: var(--bg-soft);
    border: 1px solid var(--line);
    border-radius: var(--radius);
    padding: 0.75em 0.9em;
    transition: border-color 0.25s var(--ease);
  }
  .rm__input:focus { outline: none; border-color: var(--signal); }
  .rm__input::placeholder { color: var(--muted); }

  .rm__go {
    flex: 0 0 auto;
    width: 2.9rem;
    border: 1px solid var(--signal);
    background: var(--signal);
    color: var(--bg);
    border-radius: var(--radius);
    font-size: 1.2rem;
    cursor: pointer;
    transition: transform 0.25s var(--ease), background 0.25s var(--ease);
  }
  .rm__go:hover { background: var(--ink); border-color: var(--ink); }
  .rm__go:hover span { display: inline-block; transform: translateX(3px); }

  .rm__hp { position: absolute; left: -9999px; opacity: 0; }
  .rm__done .rm__title { margin-bottom: 0; }
</style>

<script>
  const pop = document.getElementById('resume-pop') as HTMLElement | null;
  if (pop) {
    const form = pop.querySelector<HTMLFormElement>('.rm__form');
    const done = pop.querySelector<HTMLElement>('[data-resume-done]');
    const input = pop.querySelector<HTMLInputElement>('.rm__input');
    let isOpen = false;

    // Anchor the popover just under the element that opened it (right-aligned).
    const place = (anchor: HTMLElement) => {
      const r = anchor.getBoundingClientRect();
      const gap = 12;
      pop.style.top = `${r.bottom + gap}px`;
      // right-align the popover to the anchor, clamped to the viewport
      const rightOffset = Math.max(12, window.innerWidth - r.right);
      pop.style.right = `${rightOffset}px`;
      pop.style.left = 'auto';
    };

    const open = (e: Event) => {
      e.preventDefault();
      const anchor = e.currentTarget as HTMLElement;
      // reset to the form view each time
      if (form) form.hidden = false;
      if (done) done.hidden = true;
      pop.hidden = false;
      place(anchor);
      pop.classList.add('is-open');
      isOpen = true;
      // focus the field on the next frame (after it's visible)
      requestAnimationFrame(() => input?.focus());
    };

    const close = () => {
      pop.hidden = true;
      pop.classList.remove('is-open');
      isOpen = false;
    };

    document
      .querySelectorAll<HTMLElement>('[data-open-resume]')
      .forEach((el) => el.addEventListener('click', open));

    // Close on Escape
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && isOpen) close();
    });
    // Close when clicking anywhere outside the popover (page stays interactive)
    document.addEventListener('click', (e) => {
      if (!isOpen) return;
      const t = e.target as Node;
      if (!pop.contains(t) && !(t as HTMLElement).closest?.('[data-open-resume]')) {
        close();
      }
    });
    // Keep it anchored if the viewport changes while open
    window.addEventListener('resize', () => {
      if (isOpen) {
        const anchor = document.querySelector<HTMLElement>('[data-open-resume]');
        if (anchor) place(anchor);
      }
    });

    form?.addEventListener('submit', async (e) => {
      e.preventDefault();
      const data = new FormData(form);
      try {
        await fetch('https://api.web3forms.com/submit', {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json',
            Accept: 'application/json',
          },
          body: JSON.stringify(Object.fromEntries(data as any)),
        });
        // We show the thank-you regardless of the response so the UX stays
        // smooth. Delivery only actually happens once a real Web3Forms access
        // key is set in ResumeModal.astro (WEB3FORMS_ACCESS_KEY).
      } catch {
        // Offline / blocked — still show success for the UX.
      }
      if (form) form.hidden = true;
      if (done) done.hidden = false;
    });
  }
</script>
