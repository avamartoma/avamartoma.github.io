---
import { Image } from 'astro:assets';
import headshot from '../assets/ava_headshot_sticker.png';

interface Props {
  count: number;
}
const { count } = Astro.props;

// Split the name into letters so they can overlap and each carry a color.
const nameLetters = [...'ava martoma'];
const palette = ['var(--signal)', 'var(--signal-2)', 'var(--signal-3)', 'var(--signal-4)', 'var(--signal-5)'];
---

<section class="hero" id="top">
  <canvas class="hero__canvas" aria-hidden="true"></canvas>

  <div class="wrap hero__inner">
    <div class="hero__text">
      <p class="label hero__eyebrow" data-reveal>
        Artsy engineer · {count} project{count === 1 ? '' : 's'} &amp; counting
      </p>

      <h1 class="hero__name" data-reveal data-reveal-delay="60ms" aria-label="ava martoma">
        {nameLetters.map((ch, i) => (
          ch === ' '
            ? <span class="hero__space" aria-hidden="true"> </span>
            : <span class="hero__ltr" aria-hidden="true" style={`color:${palette[i % palette.length]}`}>{ch}</span>
        ))}
      </h1>

      <p class="hero__tagline" data-reveal data-reveal-delay="140ms">
        design <span class="hero__x">×</span> engineering <span class="hero__x">×</span> maker
      </p>

      <p class="hero__lede" data-reveal data-reveal-delay="200ms">
        A catalogue of experiments living at the seam between design and
        engineering — tools, toys, generative art, and the occasional
        beautiful mistake.
      </p>

      <div class="hero__cta" data-reveal data-reveal-delay="260ms">
        <a href="#work" class="btn btn--solid">View the work ↓</a>
        <a href="#about" class="btn">About me</a>
      </div>
    </div>

    <!-- Headshot sticker (top-right). Swap src for the cutout PNG when ready. -->
    <figure class="hero__photo" data-reveal data-reveal-delay="200ms">
      <Image
        src={headshot}
        alt="Ava Martoma"
        width={520}
        height={802}
        widths={[320, 520]}
        sizes="(max-width: 860px) 55vw, 340px"
        quality={90}
        format="png"
        loading="eager"
      />
    </figure>
  </div>

  <div class="hero__scroll label" aria-hidden="true">
    <span>scroll</span>
    <span class="hero__scroll-line"></span>
  </div>
</section>

<style>
  .hero {
    position: relative;
    min-height: 82vh;
    display: flex;
    align-items: center;
    overflow: hidden;
  }
  .hero__canvas {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    z-index: 0;
  }
  .hero__inner {
    position: relative;
    z-index: 1;
    padding-block: 2.5rem 4rem;
    display: grid;
    grid-template-columns: 1.35fr 0.65fr;
    gap: clamp(1.5rem, 4vw, 3.5rem);
    align-items: center;
  }
  .hero__eyebrow { margin-bottom: 1.25rem; }

  /* Big goofy bubbly name — letters overlap, each carved out with a bg outline */
  .hero__name {
    display: flex;
    flex-wrap: nowrap;
    white-space: nowrap;
    font-family: var(--font-bubble);
    font-weight: 700;
    line-height: 0.95;
    margin-bottom: 1.5rem;
    text-transform: lowercase;
    font-size: clamp(1.9rem, 6.3vw, 5.5rem);
    filter: drop-shadow(0 5px 0 rgba(0, 0, 0, 0.22));
    transition: transform 0.35s var(--ease);
  }
  .hero__name:hover { transform: rotate(-1deg) translateY(-3px); }
  .hero__ltr {
    display: inline-block;
    margin-left: -0.06em;          /* pull letters together so they overlap */
    /* bg-colored outline drawn behind the fill so an overlapping letter
       "digs into" the one beneath it, keeping each curve readable */
    -webkit-text-stroke: 0.055em var(--bg);
    paint-order: stroke fill;
    transition: transform 0.25s var(--ease);
  }
  .hero__ltr:first-child { margin-left: 0; }
  .hero__name:hover .hero__ltr { transform: translateY(-2px); }
  .hero__space { width: 0.32em; }

  .hero__photo {
    position: relative;
    justify-self: center;
    max-width: 270px;
    transform: rotate(2.5deg);
    filter: drop-shadow(0 18px 30px rgba(0, 0, 0, 0.45));
    transition: transform 0.4s var(--ease);
  }
  .hero__photo:hover { transform: rotate(-1.5deg) scale(1.02); }
  .hero__photo img {
    width: 100%;
    height: auto;
    display: block;
  }

  .hero__tagline {
    font-family: var(--font-display);
    font-weight: 500;
    font-size: clamp(1.35rem, 3.2vw, 2.1rem);
    letter-spacing: -0.01em;
    margin-bottom: 1.5rem;
  }
  .hero__x {
    color: var(--signal);
    font-weight: 400;
    padding: 0 0.12em;
  }
  .hero__accent {
    background: linear-gradient(105deg, var(--signal) 0%, var(--signal-2) 58%, var(--signal-3) 100%);
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
  }
  .hero__lede {
    color: var(--ink-soft);
    font-size: clamp(1rem, 1.6vw, 1.15rem);
    margin-bottom: 2.25rem;
  }
  .hero__cta { display: flex; flex-wrap: wrap; gap: 1rem; }

  .hero__scroll {
    position: absolute;
    bottom: 1.75rem;
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.6rem;
    z-index: 1;
  }
  .hero__scroll-line {
    width: 1px;
    height: 42px;
    background: linear-gradient(var(--muted), transparent);
    animation: drop 2s var(--ease) infinite;
  }
  @keyframes drop {
    0% { transform: scaleY(0); transform-origin: top; }
    40% { transform: scaleY(1); transform-origin: top; }
    60% { transform: scaleY(1); transform-origin: bottom; }
    100% { transform: scaleY(0); transform-origin: bottom; }
  }

  /* Stack the hero on narrow screens: photo above the text */
  @media (max-width: 860px) {
    .hero__inner {
      grid-template-columns: 1fr;
      padding-block: 5rem 4rem;
    }
    .hero__photo {
      grid-row: 1;
      justify-self: start;
      max-width: 190px;
      margin-bottom: 0.5rem;
    }
  }
</style>

<script>
  // Cursor-reactive dot field. Vanilla canvas — no dependencies.
  const canvas = document.querySelector<HTMLCanvasElement>('.hero__canvas');
  const ctx = canvas?.getContext('2d');
  const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  if (canvas && ctx) {
    let w = 0;
    let h = 0;
    let dpr = Math.min(window.devicePixelRatio || 1, 2);
    const GAP = 34;
    let points: { x: number; y: number; c: string }[] = [];

    // Holi color powder — mostly purple/blue, with hints of pink, green, yellow.
    // Weighted so purple & blue dominate; the rest are festive sprinkles.
    const PALETTE = [
      '168,85,247', '168,85,247', '168,85,247', // violet (primary)
      '67,97,238',  '67,97,238',  '67,97,238',  // blue (secondary)
      '255,92,196',                              // pink hint
      '92,230,160',                              // green hint
      '255,210,63',                              // yellow hint
    ];
    const pick = () => PALETTE[(Math.random() * PALETTE.length) | 0];

    // Pointer, in CSS pixels. Start off-screen.
    const pointer = { x: -9999, y: -9999 };
    const R = 130; // influence radius

    function build() {
      const rect = canvas!.getBoundingClientRect();
      w = rect.width;
      h = rect.height;
      dpr = Math.min(window.devicePixelRatio || 1, 2);
      canvas!.width = Math.floor(w * dpr);
      canvas!.height = Math.floor(h * dpr);
      ctx!.setTransform(dpr, 0, 0, dpr, 0, 0);

      points = [];
      for (let y = GAP / 2; y < h; y += GAP) {
        for (let x = GAP / 2; x < w; x += GAP) {
          points.push({ x, y, c: pick() });
        }
      }
    }

    function draw() {
      ctx!.clearRect(0, 0, w, h);
      for (const p of points) {
        const dx = p.x - pointer.x;
        const dy = p.y - pointer.y;
        const dist = Math.hypot(dx, dy);
        const near = Math.max(0, 1 - dist / R);

        // Push dots away from the cursor + brighten them.
        const push = near * 16;
        const ang = Math.atan2(dy, dx);
        const px = p.x + Math.cos(ang) * push;
        const py = p.y + Math.sin(ang) * push;

        const size = 1 + near * 2.4;
        const alpha = 0.16 + near * 0.7;

        ctx!.beginPath();
        ctx!.arc(px, py, size, 0, Math.PI * 2);
        if (near > 0.3) {
          // Burst into this dot's Holi color as the cursor nears.
          ctx!.fillStyle = `rgba(${p.c}, ${alpha})`;
        } else {
          ctx!.fillStyle = `rgba(165, 161, 176, ${alpha})`;
        }
        ctx!.fill();
      }
      if (!reduce) requestAnimationFrame(draw);
    }

    window.addEventListener('mousemove', (e) => {
      const rect = canvas!.getBoundingClientRect();
      pointer.x = e.clientX - rect.left;
      pointer.y = e.clientY - rect.top;
    });
    window.addEventListener('mouseleave', () => {
      pointer.x = -9999;
      pointer.y = -9999;
    });

    let resizeTimer: number;
    window.addEventListener('resize', () => {
      window.clearTimeout(resizeTimer);
      resizeTimer = window.setTimeout(() => {
        build();
        if (reduce) draw();
      }, 150);
    });

    build();
    draw(); // renders at least one frame even with reduced motion
  }
</script>
