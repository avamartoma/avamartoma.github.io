---
// Headphone popover — shows a Spotify embed of what Ava's into lately.
// Opens from any [data-open-spotify] element (the nav headphone icon).
//
// TO USE YOUR OWN MUSIC: take a playlist's share link
//   https://open.spotify.com/playlist/<ID>?...
// and paste just the <ID> below. Your auto-updating **On Repeat** playlist is
// the closest thing to "recently played" (Spotify refreshes it for you).
// You can also embed an album, artist, or single track — change the `type`.
const SPOTIFY_TYPE = 'playlist';                 // playlist | album | artist | track
const SPOTIFY_ID = '37i9dQZF1DXcBWIGoYBM5M';     // placeholder: "Today's Top Hits" — swap for yours
---

<div id="spotify-pop" class="sp" role="dialog" aria-label="What I'm listening to" hidden>
  <p class="sp__label">On repeat lately <span aria-hidden="true">🎧</span></p>
  <iframe
    class="sp__frame"
    src={`https://open.spotify.com/embed/${SPOTIFY_TYPE}/${SPOTIFY_ID}?utm_source=generator&theme=0`}
    width="100%"
    height="352"
    style="border:0;"
    allow="autoplay; clipboard-write; encrypted-media; fullscreen; picture-in-picture"
    loading="lazy"
    title="Spotify — what Ava's listening to"
  ></iframe>
</div>

<style>
  .sp {
    position: fixed;
    z-index: 200;
    width: min(22rem, calc(100vw - 2rem));
    background: var(--surface);
    color: var(--ink);
    border: 1px solid var(--line);
    border-radius: 12px;
    padding: 1rem;
    box-shadow: 0 18px 50px rgba(0, 0, 0, 0.5);
    overflow: hidden;
  }
  .sp[hidden] { display: none; }
  .sp::before {
    content: '';
    position: absolute;
    inset: 0 0 auto 0;
    height: 3px;
    background: linear-gradient(90deg, var(--signal-4), var(--signal-2));
  }
  .sp.is-open { animation: sp-in 0.22s var(--ease); }
  @keyframes sp-in {
    from { opacity: 0; transform: translateY(-8px); }
    to   { opacity: 1; transform: none; }
  }
  .sp__label {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--muted);
    margin-bottom: 0.75rem;
  }
  .sp__frame { display: block; border-radius: 10px; }
</style>

<script>
  const pop = document.getElementById('spotify-pop') as HTMLElement | null;
  if (pop) {
    let isOpen = false;

    const place = (anchor: HTMLElement) => {
      const r = anchor.getBoundingClientRect();
      pop.style.top = `${r.bottom + 12}px`;
      pop.style.right = `${Math.max(12, window.innerWidth - r.right)}px`;
      pop.style.left = 'auto';
    };
    const open = (e: Event) => {
      e.preventDefault();
      pop.hidden = false;
      place(e.currentTarget as HTMLElement);
      pop.classList.add('is-open');
      isOpen = true;
    };
    const close = () => { pop.hidden = true; pop.classList.remove('is-open'); isOpen = false; };

    document.querySelectorAll<HTMLElement>('[data-open-spotify]')
      .forEach((el) => el.addEventListener('click', open));
    document.addEventListener('keydown', (e) => { if (e.key === 'Escape' && isOpen) close(); });
    document.addEventListener('click', (e) => {
      if (!isOpen) return;
      const t = e.target as Node;
      if (!pop.contains(t) && !(t as HTMLElement).closest?.('[data-open-spotify]')) close();
    });
    window.addEventListener('resize', () => {
      if (isOpen) {
        const anchor = document.querySelector<HTMLElement>('[data-open-spotify]');
        if (anchor) place(anchor);
      }
    });
  }
</script>
