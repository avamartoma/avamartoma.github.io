---
const base = import.meta.env.BASE_URL.replace(/\/$/, '') + '/'; // always ends in one slash
const links = [
  { href: `${base}#work`, label: 'Work' },
  { href: `${base}#experience`, label: 'Experience' },
  { href: `${base}resume/`, label: 'Resume', modal: true },
  { href: `${base}#contact`, label: 'Contact' },
];
---

<header class="nav">
  <div class="wrap nav__inner">
    <a href={base} class="nav__mark" aria-label="Home — Ava Martoma">
      <svg class="nav__logo" viewBox="0 0 64 48" width="36" height="27" aria-hidden="true">
        <defs>
          <linearGradient id="aaGrad" gradientUnits="userSpaceOnUse" x1="0" y1="0" x2="64" y2="48">
            <stop offset="0" stop-color="#a855f7" />
            <stop offset="0.55" stop-color="#4361ee" />
            <stop offset="1" stop-color="#ff5cc4" />
          </linearGradient>
        </defs>
        <g fill="none" stroke="url(#aaGrad)" stroke-width="4.5" stroke-linecap="round" stroke-linejoin="round">
          <!-- two A's meeting at the base → also reads as an M, crossbars visible -->
          <path d="M4 44 L16 5 L32 44" />
          <path d="M8 31 H27" />
          <path d="M32 44 L48 5 L60 44" />
          <path d="M37 31 H56" />
        </g>
      </svg>
      <span class="nav__name">ava<em>martoma</em></span>
    </a>

    <nav class="nav__links" aria-label="Primary">
      {links.map((l) => (
        <a href={l.href} class="nav__link" data-open-resume={l.modal ? '' : undefined}>
          <span class="nav__idx">/</span>{l.label}
        </a>
      ))}
    </nav>
  </div>
</header>

<style>
  .nav {
    position: sticky;
    top: 0;
    z-index: 100;
    backdrop-filter: blur(10px);
    background: color-mix(in srgb, var(--bg) 72%, transparent);
    border-bottom: 1px solid var(--line);
  }
  .nav__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 68px;
  }
  .nav__mark {
    display: inline-flex;
    align-items: center;
    gap: 0.6em;
    font-family: var(--font-bubble);
    font-weight: 700;
    letter-spacing: 0;
    font-size: 1.2rem;
    text-transform: lowercase;
  }
  .nav__logo {
    display: block;
    flex: 0 0 auto;
    transition: transform 0.35s var(--ease);
  }
  .nav__mark:hover .nav__logo { transform: translateY(-2px) rotate(-3deg); }
  .nav__name em { color: var(--muted); font-style: normal; }

  .nav__links { display: flex; gap: clamp(1rem, 3vw, 2.25rem); }
  .nav__link {
    font-family: var(--font-mono);
    font-size: 0.82rem;
    letter-spacing: 0.06em;
    color: var(--ink-soft);
    transition: color 0.25s var(--ease);
  }
  .nav__link:hover { color: var(--ink); }
  .nav__idx { color: var(--signal); margin-right: 0.35em; }

  @media (max-width: 560px) {
    .nav__name { display: none; }
  }
</style>
