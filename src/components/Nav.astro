---
const base = import.meta.env.BASE_URL.replace(/\/$/, '') + '/'; // always ends in one slash
const links = [
  { href: `${base}#work`, label: 'Work' },
  { href: `${base}#experience`, label: 'Experience' },
  { href: `${base}resume/`, label: 'Resume', modal: true },
  { href: `${base}#contact`, label: 'Contact' },
];
---

<header class="nav">
  <div class="wrap nav__inner">
    <a href={base} class="nav__mark" aria-label="Home">
      <span class="nav__glyph">◐</span>
      <span class="nav__name">ava<em>martoma</em></span>
    </a>

    <nav class="nav__links" aria-label="Primary">
      {links.map((l) => (
        <a href={l.href} class="nav__link" data-open-resume={l.modal ? '' : undefined}>
          <span class="nav__idx">/</span>{l.label}
        </a>
      ))}
      <button class="nav__phones" data-open-spotify aria-label="What I'm listening to on Spotify">
        <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M3 18v-6a9 9 0 0 1 18 0v6" />
          <path d="M21 19a2 2 0 0 1-2 2h-1a1 1 0 0 1-1-1v-3a1 1 0 0 1 1-1h3zM3 19a2 2 0 0 0 2 2h1a1 1 0 0 0 1-1v-3a1 1 0 0 0-1-1H3z" fill="currentColor" stroke="none" />
        </svg>
      </button>
    </nav>
  </div>
</header>

<style>
  .nav {
    position: sticky;
    top: 0;
    z-index: 100;
    backdrop-filter: blur(10px);
    background: color-mix(in srgb, var(--bg) 72%, transparent);
    border-bottom: 1px solid var(--line);
  }
  .nav__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 68px;
  }
  .nav__mark {
    display: inline-flex;
    align-items: center;
    gap: 0.6em;
    font-family: var(--font-bubble);
    font-weight: 700;
    letter-spacing: 0;
    font-size: 1.2rem;
    text-transform: lowercase;
  }
  .nav__glyph {
    color: var(--signal);
    display: inline-block;
    animation: spin 9s linear infinite;
  }
  @keyframes spin { to { transform: rotate(360deg); } }
  .nav__name em { color: var(--muted); font-style: normal; }

  .nav__links { display: flex; gap: clamp(1rem, 3vw, 2.25rem); }
  .nav__link {
    font-family: var(--font-mono);
    font-size: 0.82rem;
    letter-spacing: 0.06em;
    color: var(--ink-soft);
    transition: color 0.25s var(--ease);
  }
  .nav__link:hover { color: var(--ink); }
  .nav__idx { color: var(--signal); margin-right: 0.35em; }

  .nav__phones {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    background: none;
    border: 0;
    padding: 0.2em;
    cursor: pointer;
    color: var(--ink-soft);
    transition: color 0.25s var(--ease), transform 0.25s var(--ease);
  }
  .nav__phones:hover { color: var(--signal-4); transform: translateY(-1px) scale(1.08); }

  @media (max-width: 560px) {
    .nav__name { display: none; }
  }
</style>
