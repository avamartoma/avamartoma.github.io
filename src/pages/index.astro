---
import { getCollection } from 'astro:content';
import { Image } from 'astro:assets';
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.astro';
import ProjectCard from '../components/ProjectCard.astro';
import headshot from '../assets/ava-headshot.jpeg';

const base = import.meta.env.BASE_URL.replace(/\/$/, '') + '/';

// Load projects, drop drafts, newest first.
const projects = (await getCollection('projects'))
  .filter((p) => !p.data.draft)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const stack = [
  'TypeScript', 'Python', 'Rust', 'WebGL / Canvas',
  'Astro', 'Three.js', 'Figma', 'Fabrication',
];

// Unique tags across all visible projects, most-common first, for the filter bar.
const tagCounts = new Map<string, number>();
for (const p of projects) {
  for (const t of p.data.tags) tagCounts.set(t, (tagCounts.get(t) ?? 0) + 1);
}
const allTags = [...tagCounts.entries()]
  .sort((a, b) => b[1] - a[1] || a[0].localeCompare(b[0]))
  .map(([t]) => t);
---

<Layout>
  <Hero count={projects.length} />

  <!-- ============ WORK ============ -->
  <section class="section" id="work">
    <div class="wrap">
      <header class="sec-head" data-reveal>
        <h2>Selected work</h2>
        <p class="label">{projects.length} project{projects.length === 1 ? '' : 's'} — a curated mess</p>
      </header>

      {allTags.length > 0 && (
        <div class="filters" data-reveal role="group" aria-label="Filter projects by tag">
          <button class="filter is-active" data-filter="all" aria-pressed="true">
            All <span class="filter__n">{projects.length}</span>
          </button>
          {allTags.map((t) => (
            <button class="filter" data-filter={t} aria-pressed="false">
              {t} <span class="filter__n">{tagCounts.get(t)}</span>
            </button>
          ))}
        </div>
      )}

      {projects.length === 0 ? (
        <p class="empty">
          No projects yet. Add a Markdown file to
          <code>src/content/projects/</code> and it shows up here.
        </p>
      ) : (
        <div class="grid">
          {projects.map((p, i) => (
            <ProjectCard
              href={`${base}projects/${p.id}/`}
              title={p.data.title}
              blurb={p.data.blurb}
              tags={p.data.tags}
              date={p.data.date}
              accent={p.data.accent}
              accentAlt={p.data.accentAlt}
              cover={p.data.cover}
              index={i}
            />
          ))}
        </div>
      )}
    </div>
  </section>

  <hr class="divider" />

  <!-- ============ ABOUT ============ -->
  <section class="section" id="about">
    <div class="wrap about">
      <div class="about__intro" data-reveal>
        <p class="label">About</p>
        <h2 class="about__lead">
          Half designer, half engineer,
          <span class="about__hi">fully curious.</span>
        </h2>

        <!-- Real headshot, optimized at build time by astro:assets
             (auto-resized + WebP). Source lives in src/assets/. -->
        <figure class="about__photo">
          <Image
            src={headshot}
            alt="Ava Martoma"
            width={720}
            height={1080}
            widths={[360, 720]}
            sizes="(max-width: 760px) 80vw, 360px"
            quality={80}
            loading="lazy"
          />
        </figure>
      </div>

      <div class="about__col" data-reveal data-reveal-delay="120ms">
        <p>
          I make things that sit between the studio and the terminal —
          interfaces, generative visuals, small tools, and physical builds.
          I care about the texture of software: how it feels, moves, and
          responds, not just what it does.
        </p>
        <p>
          This site is a living notebook. Some entries are polished, some
          are experiments I never finished. That's the point.
        </p>

        <div class="stack">
          <p class="label">Tools I reach for</p>
          <ul class="stack__list">
            {stack.map((s) => <li>{s}</li>)}
          </ul>
        </div>
      </div>
    </div>
  </section>
</Layout>

<style>
  .sec-head {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 1rem;
    margin-bottom: clamp(1.5rem, 3vw, 2rem);
  }

  /* Tag filter bar */
  .filters {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-bottom: clamp(2rem, 5vw, 3rem);
  }
  .filter {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    letter-spacing: 0.04em;
    color: var(--ink-soft);
    background: transparent;
    border: 1px solid var(--line);
    border-radius: 999px;
    padding: 0.45em 0.9em;
    cursor: pointer;
    display: inline-flex;
    align-items: center;
    gap: 0.5em;
    transition: border-color 0.25s var(--ease), color 0.25s var(--ease),
      background 0.25s var(--ease);
  }
  .filter:hover { border-color: var(--signal); color: var(--ink); }
  .filter__n {
    font-size: 0.62rem;
    color: var(--muted);
    transition: color 0.25s var(--ease);
  }
  .filter.is-active {
    color: var(--bg);
    background: var(--signal);
    border-color: var(--signal);
  }
  .filter.is-active .filter__n { color: var(--bg); opacity: 0.7; }

  /* Cards hidden by the active filter */
  .card[hidden] { display: none; }

  .grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(min(100%, 340px), 1fr));
    gap: var(--gap);
  }

  .empty {
    color: var(--ink-soft);
    border: 1px dashed var(--line);
    border-radius: var(--radius);
    padding: 2rem;
  }
  .empty code {
    color: var(--signal);
    font-family: var(--font-mono);
  }

  .about {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: clamp(2rem, 6vw, 5rem);
    align-items: start;
  }
  .about__lead { margin-top: 0.75rem; }
  .about__hi {
    color: var(--signal);
  }
  .about__photo {
    margin-top: 2rem;
    border: 1px solid var(--line);
    border-radius: var(--radius);
    overflow: hidden;
    max-width: 360px;
    aspect-ratio: 5 / 6;
  }
  .about__photo img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    filter: saturate(0.95) contrast(1.02);
    transition: transform 0.6s var(--ease);
  }
  .about__photo:hover img { transform: scale(1.03); }
  .about__col p { margin-bottom: 1.25rem; color: var(--ink-soft); }

  .stack { margin-top: 2rem; }
  .stack__list {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    list-style: none;
    margin-top: 0.75rem;
  }
  .stack__list li {
    font-family: var(--font-mono);
    font-size: 0.78rem;
    border: 1px solid var(--line);
    border-radius: var(--radius);
    padding: 0.4em 0.8em;
    color: var(--ink);
    transition: border-color 0.25s var(--ease), color 0.25s var(--ease);
  }
  .stack__list li:hover { border-color: var(--signal); color: var(--signal); }

  @media (max-width: 760px) {
    .about { grid-template-columns: 1fr; }
  }
</style>

<script>
  // Tag filtering for the work grid. Clicking a tag shows only cards that
  // carry it; "All" resets. Pure client-side, works on the static page.
  const filters = document.querySelectorAll<HTMLButtonElement>('.filter');
  const cards = document.querySelectorAll<HTMLElement>('.grid .card');

  filters.forEach((btn) => {
    btn.addEventListener('click', () => {
      const want = btn.dataset.filter;

      filters.forEach((b) => {
        const active = b === btn;
        b.classList.toggle('is-active', active);
        b.setAttribute('aria-pressed', String(active));
      });

      cards.forEach((card) => {
        const tags = (card.dataset.tags || '').split(',');
        const show = want === 'all' || tags.includes(want as string);
        card.hidden = !show;
      });
    });
  });
</script>
