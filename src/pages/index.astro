---
import { getCollection } from 'astro:content';
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.astro';
import ProjectCard from '../components/ProjectCard.astro';
import Experience from '../components/Experience.astro';

const base = import.meta.env.BASE_URL.replace(/\/$/, '') + '/';

// Load projects, drop drafts, newest first.
const projects = (await getCollection('projects'))
  .filter((p) => !p.data.draft)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

// Homepage shows a selection; the full, filterable list lives on /work.
const selection = projects.slice(0, 6);

// A selection of honors (non-private).
const honors = [
  'Amazon Future Engineer Scholar',
  'LinkedIn Scholar',
  'Coca-Cola Scholar',
  'Chick-fil-A Scholar',
  'NCWIT Aspirations in Computing — NJ Affiliate Winner',
  'Calvin Coolidge Senator',
  'MITES Director\u2019s Award',
  'T-Mobile Changemaker Challenge — Grand Prize',
];

const publications = [
  { title: 'Drag on Passenger Cars: CFD Analysis of Body Design Using ANSYS Fluent', venue: 'Fluids', year: 'In progress' },
  { title: 'Epidemiologic Analysis of a Postelimination Measles Outbreak in Central Ohio, 2022\u20132023', venue: 'JAMA Network', year: '2024' },
  { title: 'The Puzzle of a Silent American Epidemic (graphic)', venue: 'AAP Pediatrics in Review', year: '2022' },
  { title: 'Caring for Children of Incarcerated Parents (graphic)', venue: 'AAP Pediatrics in Review', year: '2022' },
  { title: 'Quarantine Fatigue vs. Escalating Prison Lockdowns', venue: 'Prison Legal News', year: '2020' },
  { title: 'Tips for a Successful Visit with Your Incarcerated Parent', venue: 'Rise News', year: '2019' },
];
---

<Layout>
  <Hero count={projects.length} />

  <!-- ============ WORK ============ -->
  <section class="section" id="work">
    <div class="wrap">
      <header class="sec-head" data-reveal>
        <h2>Selected work</h2>
        <p class="label">{projects.length} project{projects.length === 1 ? '' : 's'} — a curated mess</p>
      </header>

      {projects.length === 0 ? (
        <p class="empty">
          No projects yet. Add a Markdown file to
          <code>src/content/projects/</code> and it shows up here.
        </p>
      ) : (
        <>
          <div class="grid">
            {selection.map((p, i) => (
              <ProjectCard
                href={`${base}projects/${p.id}/`}
                title={p.data.title}
                blurb={p.data.blurb}
                tags={p.data.tags}
                date={p.data.date}
                accent={p.data.accent}
                accentAlt={p.data.accentAlt}
                cover={p.data.cover}
                index={i}
              />
            ))}
          </div>

          {projects.length > selection.length && (
            <div class="work-more" data-reveal>
              <a href={`${base}work/`} class="btn btn--solid">
                See all {projects.length} projects →
              </a>
            </div>
          )}
        </>
      )}
    </div>
  </section>

  <hr class="divider" />

  <Experience />

  <hr class="divider" />

  <!-- ============ HONORS + PUBLICATIONS ============ -->
  <section class="section" id="recognition">
    <div class="wrap recog">
      <div class="recog__col" data-reveal>
        <p class="label">Selected honors</p>
        <ul class="recog__honors">
          {honors.map((h) => <li>{h}</li>)}
        </ul>
      </div>

      <div class="recog__col" data-reveal data-reveal-delay="120ms">
        <p class="label">Publications</p>
        <ul class="recog__pubs">
          {publications.map((p) => (
            <li>
              <span class="recog__pub-title">{p.title}</span>
              <span class="recog__pub-meta">{p.venue} · {p.year}</span>
            </li>
          ))}
        </ul>
      </div>
    </div>
  </section>
</Layout>

<style>
  .sec-head {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 1rem;
    margin-bottom: clamp(2rem, 5vw, 3rem);
  }

  .work-more {
    display: flex;
    justify-content: center;
    margin-top: clamp(2rem, 5vw, 3rem);
  }

  .grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(min(100%, 340px), 1fr));
    gap: var(--gap);
  }

  .empty {
    color: var(--ink-soft);
    border: 1px dashed var(--line);
    border-radius: var(--radius);
    padding: 2rem;
  }
  .empty code {
    color: var(--signal);
    font-family: var(--font-mono);
  }

  .about {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: clamp(2rem, 6vw, 5rem);
    align-items: start;
  }
  .about__lead { margin-top: 0.75rem; }
  .about__hi {
    color: var(--signal);
  }
  .about__photo {
    margin-top: 2rem;
    border: 1px solid var(--line);
    border-radius: var(--radius);
    overflow: hidden;
    max-width: 360px;
    aspect-ratio: 5 / 6;
  }
  .about__photo img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    filter: saturate(0.95) contrast(1.02);
    transition: transform 0.6s var(--ease);
  }
  .about__photo:hover img { transform: scale(1.03); }
  .about__col p { margin-bottom: 1.25rem; color: var(--ink-soft); }

  .stack { margin-top: 2rem; }
  .stack__list {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    list-style: none;
    margin-top: 0.75rem;
  }
  .stack__list li {
    font-family: var(--font-mono);
    font-size: 0.78rem;
    border: 1px solid var(--line);
    border-radius: var(--radius);
    padding: 0.4em 0.8em;
    color: var(--ink);
    transition: border-color 0.25s var(--ease), color 0.25s var(--ease);
  }
  .stack__list li:hover { border-color: var(--signal); color: var(--signal); }

  @media (max-width: 760px) {
    .about { grid-template-columns: 1fr; }
  }

  /* credential line + bio extras */
  .about__cred {
    font-family: var(--font-mono);
    font-size: 0.8rem;
    color: var(--ink-soft);
    margin-top: 1rem;
    max-width: 40ch;
  }
  .about__col strong { color: var(--ink); font-weight: 500; }
  .about__play { color: var(--ink); }
  .about__edu { color: var(--ink-soft); font-size: 0.92rem; margin-top: 0.5rem; }
  .about__edu span { color: var(--muted); }

  /* Honors + Publications */
  .recog {
    display: grid;
    grid-template-columns: 1fr 1.3fr;
    gap: clamp(2rem, 6vw, 5rem);
    align-items: start;
  }
  .recog__honors,
  .recog__pubs { list-style: none; margin-top: 1rem; display: grid; gap: 0.75rem; }
  .recog__honors li {
    font-size: 0.92rem;
    color: var(--ink);
    padding-left: 1rem;
    position: relative;
  }
  .recog__honors li::before {
    content: '✦';
    position: absolute; left: 0;
    color: var(--signal);
  }
  .recog__pubs li {
    display: grid;
    gap: 0.15rem;
    padding-bottom: 0.75rem;
    border-bottom: 1px solid var(--line);
  }
  .recog__pub-title { font-size: 0.92rem; color: var(--ink); line-height: 1.4; }
  .recog__pub-meta {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    color: var(--muted);
    letter-spacing: 0.04em;
  }

  @media (max-width: 760px) {
    .recog { grid-template-columns: 1fr; }
  }
</style>
