---
import Layout from '../layouts/Layout.astro';

// No-JS fallback page for the resume popup. Uses Web3Forms (works on GitHub
// Pages). Paste your access key here too — see src/components/ResumeModal.astro
// for how to get one (free, from web3forms.com with hello@avamartoma.com).
const WEB3FORMS_ACCESS_KEY = 'YOUR_WEB3FORMS_ACCESS_KEY';
const base = import.meta.env.BASE_URL.replace(/\/$/, '') + '/';
---

<Layout
  title="Resume — Ava Martoma"
  description="Want a copy of my resume? Leave your email and I'll send it over."
>
  <section class="section resume">
    <div class="wrap resume__inner">
      <p class="label" data-reveal>The paperwork</p>
      <h1 class="resume__title" data-reveal data-reveal-delay="80ms">
        Want my <span class="resume__hi">resume</span>?
      </h1>
      <p class="resume__lede" data-reveal data-reveal-delay="160ms">
        Drop your email below and I'll send a copy your way. No newsletter, no
        spam — just me, a PDF, and probably a friendly note.
      </p>

      <form
        action="https://api.web3forms.com/submit"
        method="POST"
        class="resume__form"
        data-reveal
        data-reveal-delay="240ms"
      >
        <input type="hidden" name="access_key" value={WEB3FORMS_ACCESS_KEY} />
        <input type="hidden" name="subject" value="Someone requested your resume" />
        <input type="hidden" name="from_name" value="Resume page — avamartoma.com" />
        <!-- Web3Forms honeypot -->
        <input type="checkbox" name="botcheck" class="resume__hp" tabindex="-1" autocomplete="off" />

        <div class="field">
          <label for="name">Name <span class="opt">(optional)</span></label>
          <input type="text" id="name" name="name" autocomplete="name" placeholder="Jane Doe" />
        </div>

        <div class="field">
          <label for="email">Email</label>
          <input
            type="email"
            id="email"
            name="email"
            required
            autocomplete="email"
            placeholder="you@example.com"
          />
        </div>

        <div class="field">
          <label for="note">Note <span class="opt">(optional)</span></label>
          <textarea id="note" name="note" rows="3" placeholder="Where did you find me / what are you hiring for?"></textarea>
        </div>

        <button type="submit" class="btn btn--solid resume__submit">
          Send me the resume →
        </button>
      </form>

      <!-- Shown after a successful AJAX submit -->
      <div class="resume__done" data-done hidden>
        <h2>Got it. ✦</h2>
        <p>
          Thanks — your request landed. I'll get the resume to your inbox soon.
          In the meantime, <a href={`${base}#work`} class="arrow-link">see the work <span>→</span></a>
        </p>
      </div>
    </div>
  </section>
</Layout>

<style>
  .resume { min-height: 70vh; display: flex; align-items: center; }
  .resume__inner { max-width: 640px; }
  .resume__title { margin: 0.75rem 0 1.25rem; }
  .resume__hi {
    background: linear-gradient(105deg, var(--signal) 0%, var(--signal-2) 58%, var(--signal-3) 100%);
    -webkit-background-clip: text; background-clip: text; color: transparent;
  }
  .resume__lede { color: var(--ink-soft); margin-bottom: 2.5rem; }

  .resume__form { display: grid; gap: 1.25rem; }
  .field { display: grid; gap: 0.4rem; }
  .field label {
    font-family: var(--font-mono);
    font-size: 0.78rem;
    letter-spacing: 0.06em;
    color: var(--ink-soft);
  }
  .field .opt { color: var(--muted); }
  .field input,
  .field textarea {
    font-family: var(--font-mono);
    font-size: 0.95rem;
    color: var(--ink);
    background: var(--surface);
    border: 1px solid var(--line);
    border-radius: var(--radius);
    padding: 0.8em 0.9em;
    transition: border-color 0.25s var(--ease);
    resize: vertical;
  }
  .field input:focus,
  .field textarea:focus {
    outline: none;
    border-color: var(--signal);
  }
  .field input::placeholder,
  .field textarea::placeholder { color: var(--muted); }

  .resume__submit { justify-self: start; margin-top: 0.5rem; }

  /* Hide honeypot from real users */
  .resume__hp { position: absolute; left: -9999px; opacity: 0; }

  .resume__done h2 { margin-bottom: 0.75rem; }
  .resume__done p { color: var(--ink-soft); }
</style>

<script>
  // Progressive enhancement: submit via fetch (to Web3Forms) so the visitor
  // stays on the page and sees an inline thank-you. Without JS, the form posts
  // normally to Web3Forms, which shows its own success page — nothing breaks.
  const form = document.querySelector<HTMLFormElement>('.resume__form');
  const done = document.querySelector<HTMLElement>('[data-done]');

  if (form && done) {
    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      const data = new FormData(form);
      try {
        await fetch('https://api.web3forms.com/submit', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json', Accept: 'application/json' },
          body: JSON.stringify(Object.fromEntries(data as any)),
        });
      } catch {
        // Offline / blocked — still show the thank-you so the UX is intact.
      }
      form.hidden = true;
      done.hidden = false;
      done.scrollIntoView({ behavior: 'smooth', block: 'center' });
    });
  }
</script>
